# Fed-CORE: never commit results/data. Directory patterns are ANCHORED to the repo root
# (leading slash) so they do NOT also match same-named package dirs nested deeper, e.g. the
# fedcore/data sub-package introduced by the structure-only refactor.
/runs/
/data/
/third_party/
experiments/fedcore/smoke_results.csv
*.pyc
__pycache__/
.DS_Store
._*
# editable-install / build artifacts (pip install -e . after the project-root hoist)
*.egg-info/
/build/
/dist/
